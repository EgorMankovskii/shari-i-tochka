DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_ALLOWED_HOSTS=example.ru,www.example.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.ru,https://www.example.ru
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_ADMIN_PATH=secure-admin-panel/
DJANGO_STUDIO_PATH=secure-studio-panel/
DJANGO_PANEL_BASIC_AUTH_USERNAME=change-this-login
DJANGO_PANEL_BASIC_AUTH_PASSWORD=change-this-second-password
DJANGO_PANEL_ALLOWED_IPS=
DJANGO_ADMIN_TRUST_PROXY_HEADERS=True

# Use PostgreSQL in production.
DATABASE_URL=postgresql://shari_user:replace-password@127.0.0.1:5432/shari_db
