[Unit]
Description=Gunicorn for Shari i Tochka
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/Shari-i-tochka
EnvironmentFile=/var/www/Shari-i-tochka/.env
ExecStart=/var/www/Shari-i-tochka/.venv/bin/gunicorn sitecore.wsgi:application \
    --bind 127.0.0.1:8001 \
    --workers 3 \
    --timeout 120
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
